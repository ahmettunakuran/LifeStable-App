rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    // Checks if the user is authenticated via Firebase Auth
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user's UID matches the document ID
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can only read their own profile data
      allow read: if isSignedIn() && isOwner(userId);

      // Users can only create their own profile during registration
      allow create: if isSignedIn() && isOwner(userId);

      /**
       * Update Rule (Security Baseline):
       * Users can update their profile, BUT they are strictly forbidden from
       * modifying sensitive fields like 'role', 'points', or 'createdAt'
       * directly from the mobile app (preventing fraud and privilege escalation).
       */
      allow update: if isSignedIn() && isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                    .hasAny(['role', 'points', 'createdAt']);

      // Prevent profile deletion from the client side for data integrity
      allow delete: if false;
    }

    // Rules for 'habits' or 'tasks' (Ensures data isolation between users)
    match /habits/{habitId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // GLOBAL CATCH-ALL: Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
