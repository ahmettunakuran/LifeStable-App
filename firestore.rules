rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/team_members/$(request.auth.uid + '_' + teamId)) ||
        exists(/databases/$(database)/documents/team_members/$(teamId + '_' + request.auth.uid));
        // Note: The ID format depends on how TeamService creates it. 
        // Let's check TeamService.createTeam and joinTeamWithCode.
    }
    
    // Better team membership check: query team_members collection
    function isMemberOfTeam(teamId) {
       return isSignedIn() && get(/databases/$(database)/documents/teams/$(teamId)).data != null; // Placeholder
    }

    match /users/{userId} {
      allow read, create: if isOwner(userId);
      allow update: if isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'points', 'createdAt', 'level', 'habitStreak']);
      allow delete: if false;

      match /domains/{domainId} {
        allow read, write: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      match /habits/{habitId} {
        allow read, write: if isOwner(userId);
      }

      match /calendar_events/{eventId} {
        allow read, write: if isOwner(userId);
      }

      // Public metadata only. Client may read connection state.
      match /external_accounts/{provider} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Server-only secrets.
      match /external_credentials/{provider} {
        allow read, write: if false;
      }

      // Server-only OAuth nonce/state.
      match /oauth_states/{provider} {
        allow read, write: if false;
      }

      // Server-only mapping collection.
      match /external_event_map/{mapId} {
        allow read, write: if false;
      }

      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Top-level team collections ───────────────────────
    match /teams/{teamId} {
      allow read: if isSignedIn(); // Simplified for now, should check membership if sensitive
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();

      match /tasks/{taskId} {
        allow read, write: if isSignedIn(); // Simplified for now
      }
      match /calendar_events/{eventId} {
        allow read, write: if isSignedIn();
      }
    }

    match /team_members/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
